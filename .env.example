# Token de autenticación de GitHub
# Generalo en: https://github.com/settings/tokens
# Scopes necesarios: repo, user, admin:org, workflow
GITHUB_TOKEN=ghp_tu_token_aqui

# Nivel de logging: debug, info, warn, error
# debug: muestra todo el detalle
# info: muestra operaciones principales (recomendado para producción)
LOG_LEVEL=info